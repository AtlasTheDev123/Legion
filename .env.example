# Legion Core Claw - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit actual secrets or tokens to version control

# ==============================================================================
# LLM & AI Configuration
# ==============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
OPENAI_API_KEY=sk-...your-api-key...
MISTRAL_API_KEY=
LOCALAI_BASE_URL=http://localhost:8080

# ==============================================================================
# Telegram Bot Configuration
# ==============================================================================
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
ALLOWED_USERS=123456789,987654321
DEFAULT_AUTH_TOKEN=your-secure-auth-token-here

# ==============================================================================
# Execution & Sandbox Configuration
# ==============================================================================
SANDBOX_MODE=simulated
ALLOW_DIRECT_EXECUTION=0
ALLOW_TELEGRAM_ACTIONS=0

# ==============================================================================
# API Server Configuration
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=0

# ==============================================================================
# Agent & Orchestration Configuration
# ==============================================================================
MAX_AGENTS=10
DEFAULT_AGENT_TIMEOUT=300

# ==============================================================================
# Security & Compliance
# ==============================================================================
ENABLE_AUDIT_LOG=1
ENABLE_SECURITY_SCANNING=1

# ==============================================================================
# Database Configuration (optional)
# ==============================================================================
MONGODB_URI=mongodb://localhost:27017/legion
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=INFO
LOG_FILE=legion-core-claw.log
