# Example env file for local development (DO NOT commit your real token)
# Copy to `.env` and populate the real values or load secrets from your host/CI secret store.

TELEGRAM_BOT_TOKEN=REPLACE_ME
# Must be explicitly enabled to perform real sends/calls. Default: 0 (simulated)
ALLOW_TELEGRAM_ACTIONS=0
# Optional: admin/chat id used for admin notifications
TELEGRAM_ADMIN_CHAT_ID=
