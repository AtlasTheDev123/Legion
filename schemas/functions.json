                           "required":  [
                                            "vuln_id",
                                            "repo_path"
                                        ]
                       },
        "example":  {
                        "vuln_id":  "VULN-001",
                        "repo_path":  "/projects/atlas-core"
                    }
    },
    {
        "name":  "run_port_scan",
        "description":  "Perform a port scan against a target host or network segment  ONLY with authorization and in isolated lab environments.",
        "parameters":  {
                           "type":  "object",
                           "properties":  {
                                              "target_ip":  {
                                                                "type":  "string"
                                                            },
                                              "ports":  {
                                                            "type":  "string",
                                                            "description":  "Port range, e.g. 1-1024 or comma list"
                                                        },
                                              "authorization_token":  {
                                                                          "type":  "string"
                                                                      }
                                          },
                           "required":  [
                                            "target_ip",
                                            "authorization_token"
                                        ]
                       },
        "example":  {
                        "target_ip":  "127.0.0.1",
                        "ports":  "1-1024",
                        "authorization_token":  "[REDACTED_LAB_AUTH]"
                    }
    },
    {
        "name":  "spawn_agent",
        "description":  "Create and start an orchestration agent instance with supplied role and capabilities.",
